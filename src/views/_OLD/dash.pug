extends layout

mixin medalsmk
      -var it = 0;
      while it < 9
        if user.modules.medals[it] != undefined
          -var medal_icon = user.modules.medals[it][0]
        else
          -var medal_icon = [0,0]


        if medal_icon!=0 && user.modules.medals[it]!=[0,0]
          img(src="/medals/"+medal_icon+".png")
        else
          img(src="/medals/undefined.png")
          //li.drop.ui-droppable.medalSlot
        -it++

mixin mockup
  div.profileMock(style="z-index:999; position:relative; transform:scale(.7) translateX(-25%) translateY(-28%)")
      img.mainframe(src="http://i.imgur.com/PuDHUx5.png" style="max-width:400px !important")
      div#bgm
        img.level-item(src="/backdrops/"+user.modules.bgID+".png")#userbp
      div#ptxmock
        p= user.modules.persotext
      div#medalmocks.level
        +medalsmk
      div.hexagon(style="background-image:url('"+userinfo.pix+"')")
          div.hexTop
          div.hexBottom

