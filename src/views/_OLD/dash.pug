            .level-left
                div
                  p.title: b= userinfo.uname
                  p.subtitle= userinfo.name
            .level-item
                p(class="subtitle")!= "<b>ID </b>"+userinfo.id
            .level-item
            .level-item


      div
        .tabs.is-centered.is-boxed.striped-pink

          ul
            li#a1.tab.is-active(data-target="overviewSettings"): a(href="#/overview")= translation.website.overview || "Overview"
            li#a2.tab(data-target="profileSettings").is-hidden-mobile: a(href="#/profile")= translation.website.profile ||  "Profile"
            li#a3.tab(data-target="guildsets"): a(href="#/servers")= translation.website.myServs|| "My Servers"
            li#a4.tab(data-target="soon").is-hidden-mobile: a(href="#/inventory")=translation.website.inventory||  "Inventory"

  .nano: .nano-content: .container
        br
        #overviewSettings.tabcontainer.hidden
            include dash/overview
        #profileSettings.tabcontainer.hidden.is-hidden-mobile
            include dash/profile
        #guildsets.tabcontainer.hidden
            include dash/guilds
        #soon.tabcontainer.hidden.is-hidden-mobile
            include soon

