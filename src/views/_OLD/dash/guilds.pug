div.message-body
  style.
    .nopePol_duo{
      display:none;
    }
    .gcard{height:60px;width:350px;margin:8px;display:inline-block}
    @media screen and (max-width:800px){
      .gcard{
        width:100%;
      }
    }
  if bot.discordOutage == true
    .title "DISCORD UNDERGOING MAJOR OUTAGE"
    .subtitle "Pollux Database works fine, but any Discord-related Action will not be saved!"
  else
  
    each g in guilds
        if g.present !== true && g.perms != "owner" || g.perms == "commoner"
          -var p = "nopePol"
        else
          -var p = "yepPol"
        div.card.gcard(class=p+"_duo")
          div.hexContainer
            div.smolHex(class=p style="background-image:url('"+g.icon+"')")
              div.shexTop
              div.shexBottom
          //img.is-round(src=g[0] width="48px")
          p.mid(class=p)= g.name
          div(class=`${pres}`)
            div.flair(class=g.perms title=`You are a ${g.perms} in this Server`)
          if g.perms == 'mod' || g.perms =='adm'||g.perms =='owner'&& g.present
            a(href="/myGuilds/"+g.id)
              button.button.is-small.manage Manage
            //div.hasPollux
          if g.perms == "owner" && !g.present
            a(href="https://goo.gl/qkGqqU")
              button.button.is-small.is-primary.is-outlined.addme Add Pollux to this Server
            //div.hasPollux.no
