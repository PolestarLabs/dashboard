                    hr.plx-divider-icon

                    .buffer
                        - var links = ["https://media.discordapp.net/attachments/488142034776096772/779353424612819014/unknown.png","/images/showcase/roulette.png","https://media.discordapp.net/attachments/488142034776096772/779359215596470272/unknown.png","https://media.discordapp.net/attachments/488142034776096772/779359836680618014/unknown.png"]
                        .p-slides(plx-slideshow="autoplay:true; autoplay-interval=1500")
