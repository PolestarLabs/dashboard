                        - var link = "https://media.discordapp.net/attachments/488142034776096772/779360698680606760/unknown.png" // dly
                        a(href=link)
                            img(plx-img src=link)
                        h4.subtitle.minititle Revamped Daily Bonuses! 
                        p 
