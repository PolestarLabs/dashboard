                        - var links = ["/images/showcase/event.webm","https://cdn.discordapp.com/attachments/488142034776096772/779373448395751454/unknown.png","/images/showcase/evt1.png","https://media.discordapp.net/attachments/488142034776096772/779372702611800114/unknown.png"]
                        .buffer.p-slides(plx-slideshow="autoplay:true; autoplay-interval=1500")
