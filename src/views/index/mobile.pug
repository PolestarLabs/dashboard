mixin minifooter()
    .minifooter.plx-flex.plx-flex-around()
        .magic-outline.blue.plx-button.plx-invisible
        block
        
mixin bubble(item,opts={})
    .pollux-container(  style= opts.dim ? "mask: linear-gradient(135deg, #FFF 20%,#0000 80%);" : "")
        .content-holder.bubble
            .backdrop.screen-1(style=`background-image: ${opts.bgImg}`)
            .img-container(style=`transform: ${opts.transform}`)
                img(plx-img src="/images/pollux/"+(item||"polluxv8")+".png" )

- let nodrift = true
style
    include mobile.css

.slide.plx-position-relative
    //(plx-switcher="finite: true; draggable: true")
    //.plx-switcher-container
    //ul.plx-subnav.plx-tab-dash
        li: a 1 
        li: a 2
        li: a 3
        li: a 4
    div 
        ul.plx-switcher.screens#screens

            li.screenslide.plx-position-relative: .screen#start
                +bubble()
                .buffer
                h1.title Pollux
                h3.subtitle Your new favorite assistant
                if !userinfo
                    .infobox
                        p
                            | A feature-rich assistant focused in and entertainment and social activities.
                            br
                            br
                            | Pollux comes with a variety of cool functionalities and minigames with unmatched depth and ellaborate visuals.
                        p
                            | Count on her to keep the activity around your community always blooming.
                    a(href="/auth").magic-outline.plx-button.login-main
                        i.fas.fa-sign-in-alt
                        span &#x2002 LOGIN
                else
                    .infobox
                        p Welcome back, #{userinfo.uname}!
                    a(href="/dash").magic-outline.plx-button.login-main.dashboard
                            i.fas.fa-address-card
                            span &#x2002 DASHBOARD
                    .plx-flex.plx-flex-around
                        a(href="/commands").magic-outline.plx-button.login-main.small.comms
                            i.fas.fa-cogs
                            span &#x2002 COMMANDS
                        a(href="/discord").magic-outline.plx-button.login-main.small.supp
                            i.fas.fa-question
