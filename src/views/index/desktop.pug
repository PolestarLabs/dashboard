mixin fancyCard(title,main,icon,direction)
    .fancy-card(class=direction)
        .fancy-card-background.clipped-all
        .fancy-card-frame
        .fancy-card-visuals.clipped-bottom
            img(src=main plx-scrollspy="cls: plx-animation-slide-bottom; repeat: true").main
            .icon
                img(src=icon plx-scrollspy="cls: plx-animation-scale-up; repeat: true")
        .fancy-card-container
            .fancy-card-textarea
                block
            .fancy-card-floating-title
                h3(plx-scrollspy="cls: plx-animation-slide-"+direction+"-medium; repeat: true; delay:100").supershadow-tools!= title

