    br
    br

each d in DCKINFO.map(x=>x.localizer)
        style
            |    body::after{
            |        position:absolute; width:0; height:0; overflow:hidden; z-index:-1;  
            |        content:url('/build/cards/casino/#{d}/backface.png')
            |        content:url('/build/cards/casino/#{d}/SA.png')
            |         url('/build/cards/casino/#{d}/HQ.png')
            |          url('/build/cards/casino/#{d}/C10.png')
            |          url('/build/cards/casino/#{d}/D7.png')
            |          url('/build/cards/casino/#{d}/SJ.png')
            |          url('/build/cards/casino/#{d}/H2.png')
            |          url('/build/cards/casino/#{d}/CK.png')
            |           url('/build/cards/casino/#{d}/D3.png');   
            |    }     
section.plx-container#custom-options
    h1.title Customization
    h3.subtitle Personalize other things which you're allowed to
    hr
    .plx-container.plx-grid
        #select-deck.plx-width-1-1(class='plx-width-1-2@m')
            h3.title Casino Deck
            h5.subtitle Deck used in BLACKJACK and future Casino minigames   
            v-select(
                @input="onChangeDeck",
                v-model="selectDeckCasino"
                :options= "decksAvailableCasino",
                :filterable= "false",
                :clearable= "false",
                :searchable= "false",
                :select-on-tab = "false",
                :value= `decksAvailableCasino.find(x=>x.id=='${myDeckCasino.id}')`,
                label='name',
                @search:blur="isSearchBlurCasino=true",
                @search:focus="isSearchBlurCasino=false"
            ) 
                template(slot='selected-option', slot-scope='option')
                    span(style='transform:translateY(-5px)')
                        .plx-rarity-icon(:class='option.rarity') 
                        span.sticker-sel-span &#x2000 {{option.name}}
                        
                template(slot='option', slot-scope='option')
                    .stick-sel-opt
                        .deck-backface(:style="`background-image:url('/build/cards/casino/${option.localizer}/backface.png')`"  class="plx-visible@m")
                        .deck-icon(:style="`background-image:url('/build/cards/casino/${option.localizer}/HQ.png')`"  class="plx-visible@m")
                        span(style='transform:translateY(-5px)')
                            .plx-rarity-icon(:class='option.rarity')
                            | &#x2000 {{option.name}} 
            .deck-demo.casino
                each card,y in ['SA','HQ','C10','D7','SJ','H2','CK','D3']
                    transition(name="deck-reveal" )
                        .deckcard(:style=`{'transition-delay': '${1+.013*(y*y)}s'}` v-show="isSearchBlurCasino")
                            .face(:style="`background-image:url('/build/cards/casino/${selectDeckCasino.localizer}/"+card+".png')`")
                                .backface(:style="`background-image:url('/build/cards/casino/${selectDeckCasino.localizer}/backface.png')`")
            
        
        #select-deck.plx-width-1-1(class='plx-width-1-2@m')
            h3.title Tarot Deck
            h5.subtitle Deck used in Tarot spreads and minigames   
            v-select(
                @input="onChangeDeck",
                v-model="selectDeckTarot"
                :options= "decksAvailableTarot",
                :filterable= "false",
                :clearable= "false",
                :searchable= "false",
                :select-on-tab = "false",
                :value= `decksAvailableTarot.find(x=>x.id=='${myDeckTarot.id}')`,
                label='name',
                @search:blur="isSearchBlurTarot=true",
                @search:focus="isSearchBlurTarot=false"
            ) 
                template(slot='selected-option', slot-scope='option')
                    span(style='transform:translateY(-5px)')
                        .plx-rarity-icon(:class='option.rarity') 
                        span.sticker-sel-span &#x2000 {{option.name}}
                        
                template(slot='option', slot-scope='option')
                    .stick-sel-opt
                        .deck-backface(:style="`background-image:url('/build/cards/tarot/${option.localizer}/backface.png')`"  class="plx-visible@m")
                        .deck-icon(:style="`background-image:url('/build/cards/tarot/${option.localizer}/star.png')`"  class="plx-visible@m")
                        span(style='transform:translateY(-5px)')
                            .plx-rarity-icon(:class='option.rarity')
                            | &#x2000 {{option.name}} 
                            span.author by 
                                a(:href='option.author_link') {{option.author}}
            .deck-demo.tarot
                each card,y in ['lovers','death','hanged','chariot','hiero','magician','moon','devil']
                    transition(name="deck-reveal" )
                        .deckcard(:style=`{'transition-delay': '${1+.013*(y*y)}s'}` v-show="isSearchBlurTarot")
                            .face(:style="`background-image:url('/build/cards/tarot/${selectDeckTarot.localizer}/"+card+".png')`")
                                .backface(:style="`background-image:url('/build/cards/tarot/${selectDeckTarot.localizer}/backface.png')`")
            
    br   
    .plx-flex.plx-flex-center
        a(@click='howToDeck()').magic-outline.plx-button.plx-margin-left.plx-margin-bottom(type='button')#howtoDeck
                i.fas.fa-question              
                span &#x2002 How to obtain more decks
    hr
    br
    br
    br

script
    include settings_menu.js

    