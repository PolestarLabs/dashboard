include ../tools/mixins
-const NOTIFS = ((userdata.switches||{}).notifications||{})
section.plx-container#settings-options
    h1.title Notifications
    h3.subtitle Configure what to be notified via DMs to you
    hr
    .plx-grid
        div(style="display: inline-flex;")
            +pinkSwitch("enable-dm-alerts-sv-changes", null ,(userdata.switches||{ownerNotif:false}).ownerNotif)
                p
                    b  Enable DM Notifications on Server Changes
                    br
                    i  Notify when someone does changes to settings in a server you own.

            +pinkSwitch("dm-welcome-opt-out","Opt-out of Welcome DMs",(userdata.switches||{dmWelcome:false}).dmWelcome)
                 p
                    b  Enable Welcome DM Messages
                    br
                    i  Opt-in or out from receiving DM messages upon joining a server that uses them.
        
        div.plx-width-1-1
            ul(plx-accordion="multiple: true").categs-container
                -let item= "misc-notifs" 
                li.categ(id='misc_notifications')
                    .plx-magic-input
                        .plx-pink-check                            
                            input.markall(data-cat=item type="checkbox" id=item name=item checked= false )
                            label(for=item) 
                    
                    a.plx-accordion-title
                            h5.title Receive DMs about updates and new features
                            .help Receive new commands, bugfixes, cosmetics-packs releases, announcements, patch notes directly in your DMS 
                    .plx-accordion-content
                        .container                           

                            -var subitem = 'new_command' 
                            label.a-comand(class="cat_misc-notifs")
                                input.command-toggle(type="checkbox" id=subitem checked= (typeof NOTIFS.newCommand == 'boolean') ? NOTIFS.newCommand : false)  
                                span New Commands
                            -subitem    = 'patch_note' 
                            label.a-comand(class="cat_misc-notifs")
                                input.command-toggle(type="checkbox" id=subitem checked= (typeof NOTIFS.patchNotes == 'boolean') ? NOTIFS.patchNotes : false)  
                                span Patch Notes
                            -subitem    = 'events' 
                            label.a-comand(class="cat_misc-notifs")
                                input.command-toggle(type="checkbox" id=subitem checked= (typeof NOTIFS.events == 'boolean') ? NOTIFS.events : true)  
                                span Events
                            -subitem    = 'cosmetics' 
                            label.a-comand(class="cat_misc-notifs")
                                input.command-toggle(type="checkbox" id=subitem checked= (typeof NOTIFS.newCosmetics == 'boolean') ? NOTIFS.newCosmetics : false)  
                                span New Cosmetics
                            -subitem    = 'general_announcements' 
                            label.a-comand(class="cat_misc-notifs")
                                input.command-toggle(type="checkbox" id=subitem checked= (typeof NOTIFS.miscAnnouncements == 'boolean') ? NOTIFS.miscAnnouncements : false)  
                                span Other Pollux Announcements
                            -subitem    = 'partner_announcements' 
                            label.a-comand(class="cat_misc-notifs")
                                input.command-toggle(type="checkbox" id=subitem checked= (typeof NOTIFS.partnerAnnouncements == 'boolean') ? NOTIFS.partnerAnnouncements : false)  
                                span Partners Announcements

    hr.plx-divider-icon
    br
    br
    br

-const ATTR = (userdata.switches||{}).variables || []        
-const SKINS = (userdata.modules.skins || {})

-const myDeckCasino = SKINS.blackjack || "default"
-const myDeckTarot  = SKINS.tarot || "default"

-const myDecks  = DCKINFO.filter(t=>userdata.modules.skinInventory.includes(t.id))

-const DEFAULT_DECK_C = {for:'casino', id:'casino_default',name: 'Standard Casino Deck', rarity: 'C', localizer:'default'}
-const DEFAULT_DECK_T = {for:'tarot', id:'tarot_persona3',name: 'Persona 3', rarity: 'C', localizer:'persona3'}

-myDecks.unshift(DEFAULT_DECK_C)
-myDecks.unshift(DEFAULT_DECK_T)

script var decksAvailableCasino = !{JSON.stringify(myDecks.filter(d=>d.for=='casino') )} 
script var myDeckCasino = !{JSON.stringify(DCKINFO.find(x=>x.id==myDeckCasino)||DEFAULT_DECK_C )} 
script var decksAvailableTarot = !{JSON.stringify(myDecks.filter(d=>d.for=='tarot') )} 
script var myDeckTarot = !{JSON.stringify(DCKINFO.find(x=>x.id==myDeckTarot)||DEFAULT_DECK_T )} 
script var ATTR = !{JSON.stringify(ATTR)} 
 

style
    include attribs.css

section.plx-container#roleplay
    h1.title RPG Attributes / Annotations
    h3.subtitle Manage your Roleplay Module attribute list

    .attrib-list.plx-flex.plx-flex-wrap
        .attrib( v-for="(attr,i) in attributes" :class=`(highlight == attr.tag ? 'is-highlighted' : '' ) + (attr.tag.startsWith('!')? 'macro' : '' )` )
            a(@click="attributes=attributes.filter((_,y)=>y!=i)").tag-delete: i.fas.fa-times-circle

            .tag
                b(v-if="editing!==i"  @click="editing=i") {{attr.tag}}
                b.editing(v-if="editing===i")
                    input(type='text' v-model="attr.tag"  @keyup.tab="editing=attributes[i].tag"  @keyup.enter="editing=null" @focus="$event.target.select()")
                    a.close(@click="editing=null"): i.fas.fa-times-circle

            .value.editing(v-if="editing==attr.tag")
                input(type='text' v-model="attr.value" @keyup.enter="editing=null"  @focus="$event.target.select()" )
                a.close(@click="editing=null"): i.fas.fa-times-circle

            .value(v-if="editing!=attr.tag" @click="editing=attr.tag")
                .piece(v-for="(part,i) in attr.value.match(/[0-9]?d[0-9]+|[A-z]+|[\(\)+\/*\-]|[0-9]+/g)",
                    :class="isMacro(attr) && isTag(part) ? 'm-tag' : isMacro(attr) && !isTag(part) && isDice(part) ? 'is-dice'+' is-'+diceValue(part) : '' ",
                    @mouseover=`isMacro(attr) &&  isTag(part) ? highlight = part : null`,
                    @mouseout='isMacro(attr) && isTag(part) ? highlight = null : null',
                    :plx-tooltip="isMacro(attr) && isTag(part) ? attributes.find(x=>x.tag==part).value : null"
                )
                    
                    span.dice( v-if="isMacro(attr) && diceValue(part) == '8'")
