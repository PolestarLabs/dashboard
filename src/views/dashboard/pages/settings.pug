                    span.dice(v-else-if="isMacro(attr) && diceValue(part) == '12'")
                        svg.svg-inline--fa.fa-dice-d12.fa-w-16(aria-hidden='true', focusable='false', data-prefix='fal', data-icon='dice-d12', role='img', xmlns='http://www.w3.org/2000/svg', viewBox='0 0 512 512')
