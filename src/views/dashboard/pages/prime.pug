-let PRIME_DATA = JSON.parse(JSON.stringify(userdata||{})).prime;

script var availablePolluxUsers = !{ JSON.stringify( (POLLUX_USERS).filter(x=>x.category!="alpha").map(x=>x.user) ) }
style 
    include prime.css

.plx-container#primedata
    if PRIME_DATA && PRIME_DATA.active 
        h2.title You are a Prime user! 
       

        section#details.plx-flex.plx-flex-wrap
            .titles
                h3.title #{ capitalize(PRIME_DATA.tier) } Supporter
                img(src=`/images/donate/${PRIME_DATA.tier}.png`)
            .perks
                li Custom Background:  
                    .tick( class=(PRIME_DATA.custom_background ? "yep" : "nope") )
                        
                li Custom Handle: 
                    .tick( class=(PRIME_DATA.custom_handle ? "yep" : "nope") )
                        
                li Custom Shop: 
                    .tick( class=(PRIME_DATA.custom_shop ? "yep" : "nope") )
                        
                li Boosted Dailies: 
                    .tick( class=(true ? "yep" : "nope") )
                        
                li Treehouse Access:  
                    .tick( class=(true ? "yep" : "nope") )
                        
                li Priority Support:  
                    .tick( class=(true ? "yep" : "nope") )
                        
                li Tracker:  
                    span= userdata.counters.prime_streak[PRIME_DATA.tier]
                    

            

        section#prime_servers
            h3.title Current Prime Servers
                
            .primes-parent
                div(v-for="server in servers" :data-svid="server.id" v-if="servers.length").prime-server
                    .icon: img(:alt="server.id[0]" :src="server.meta.icon")
                    .info 
                        .name {{server.meta.name||server.name||"Unknown"}}
                        .clients 
                            .client(v-for="client in users.filter(u=> (server.activeClients||['578913818961248256','271394014358405121']).includes(u.id))")
                                .avatar: img(:plx-tooltip=" client.fname+' | '+client.id", :src="`https://cdn.discordapp.com/avatars/${client.id}/${client.avatar}.png?size=64`")
                            


            p
                | Total Tokens: #{PRIME_DATA.maxServers}
                | Tokens Used: #{(PRIME_DATA.servers||{}).length || 0}

            h3.title Enable Prime for a new Server:
            .prime-select-container
                .prime-select-row
                    button(:class='((!( (userPrimeStatus.servers||{}).length || 0 )||!serverToPrime.id)?"disabled red":"")' @click="").magic-outline.plx-button.plx-margin-left.plx-margin-bottom#assignPrime Activate!
                    div 
                    v-select(                
                        v-model="serverToPrime"
                        :options= "primable_servers",
                        :filterable= "false",
                        :clearable= "false",
                        :searchable= "false",
                        :select-on-tab = "false",
                        :value= `serverToPrime.id`,
                        label='sv',      
                        :selectable="option => !servers.find(x=>x.id===option.id)"
                    ) 
                        template(slot='selected-option', slot-scope='option')
                            .selected-item
                                .sv-icon.plx-rounded: img(:alt="option.name[0]" :src="`https://cdn.discordapp.com/icons/${option.id}/${option.icon}.png?size=32`" ) 
                                .texts
                                    span.label &#x2000 {{option.name}}
                                    span.description {{option.id}}          
                        template(slot='option', slot-scope='option')
                            .sel-opt( )
                                .sv-icon.plx-rounded: img(:alt="option.name[0]" :src="`https://cdn.discordapp.com/icons/${option.id}/${option.icon}.png?size=32`") 
                                .texts
                                    span.label &#x2000 {{option.name}}
                                    span(v-if="servers.find(x=>x.id===option.id)").description Prime already in this server
                                    span(v-else).description {{option.id}}
                
                    
                .tip.plx-text-danger(v-if="!( (userPrimeStatus.servers||{}).length || 0 )") Max Servers Reached!
                .tip.plx-text-danger(v-else-if="!serverToPrime.id") Select a Server first!
                hr
                b Select the appropriate attire:
                .select-flavor
                    each polly in POLLUX_USERS.filter(x=>x.category=="premium")
                        .polluxSelect(@click=`selectedFlavor = '${polly.internal_name}'`, :class=`selectedFlavor == '${polly.internal_name}' ? 'selected' : '' `)
                            .avatar
                                img(src=`https://cdn.discordapp.com/avatars/${polly.id}/${polly.user.avatar}.png?size=128`)
                            .name= polly.friendly_name
                
                        

            

            


    else
        h2.title You are not a Prime user! 
        link(rel="stylesheet" href="/css/tierboxes.css")
        include ../../index/parts/prime

    br
    br
    br
    br
            
script 
    include prime.js 
    