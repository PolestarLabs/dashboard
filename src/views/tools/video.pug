doctype html
html
  head
    meta(property='og:site_name' content=ogname||"⭐ Pollux")
    meta(property='og:title' content=ogtitle||"Video")
    meta(property='og:url' content='/build/galleries/'+video)
    meta(property='og:type' content='video')
    meta(property='og:video' content='/build/galleries/'+video)
    meta(property='theme-color' content=ogcolor||"#FF3355")
  body
    style.
      body {
        background-color: black;
      }
    table(width='100%' height='100%')
      tbody
        tr
          td(style='text-align: center; vertical-align: middle;')
            video(src='/build/galleries/'+video alt=video)
