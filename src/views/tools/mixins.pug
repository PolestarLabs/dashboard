    var groupBy = function(xs, key) {
    return xs.reduce(function(rv, x) {
    (rv[x[key]] = rv[x[key]] || []).push(x);
    return rv;
    }, {});
    };
    
    function miliarize(numstring,strict,symbol){
      let sym = symbol||"." 
      if (!numstring)return 0 ;
        if (typeof numstring == "number"){
            numstring = numstring.toString()
        }
        if(numstring.length < 4)return numstring;

        var stashe = numstring.replace(/\B(?=(\d{3})+(?!\d))/g, sym).toString();

        if(strict==="ultra"){
            return stashe;
        }
        
        if(strict){
            var stash = stashe.split(sym)
        switch(stash.length){
            case 1:
                return stash;
            case 2:
                if(stash[1]!="000") break;
                return stash[0]+"K";
            case 3:
                if(stash[2]!="000") break;
                return stash[0]+sym+stash[1][0]+stash[1][1]+"Mi";
            case 4:
                if(stash[3]!="000") break;
                return stash[0]+sym+stash[1][0]+stash[1][1]+"Bi";
             }

            return stashe;
        }        

        stash = stashe.split(sym)
        switch(stash.length){
            case 1:
                return stash.join(" ");
            case 2:
                if(stash[0].length<=1) break;
                return stash[0]+"K";
            case 3:
                return stash[0]+"Mi";
            case 4:
                return stash[0]+"Bi";
             }
         return stashe;
      }


mixin rotated-sidebar(list)
  ul#side-rotation-nav.plx-subnav.plx-subnav-pill(plx-scrollspy-nav="closest: li; scroll: true; offset: 180; " )
    each item in list.reverse()
      if item
        li
          a(href= item.href || item[0])= item.item || item[1]
mixin pinkInput(id,label,typee,value,placeholder)
  .plx-magic-input
    if label
      .plx-flex   
          .plx-flex-start  
            .plx-pink-input
              input(type=typee id=id value=value placeholder=placeholder  name=id)
              label(for=id)
          .plx-flex-end   
            span!= label
    else 
      .plx-pink-input
        input(type=typee id=id value=value placeholder=placeholder  name=id)
        


mixin pinkSwitch(id,label,onoff)
  .plx-magic-input
    if label || block
      .plx-flex
          .plx-flex-start  
            .plx-pink-check
              input(type="checkbox" id=id name=id checked=onoff||false )
              label(for=id)
          .plx-flex-end   
            if block
                block
            else
                span!= label
    else 
      .plx-pink-check
        input(type="checkbox" id=id name=id  checked=onoff||false)
        label(for=id)

mixin channelSelect(id,channels,defaulte)
  .plx-pink-input
      select(id=id name=id)
          each chn in channels
            if chn.id === defaulte
              option(value=chn.id id=chn.id selected)= (chn.type==0?"#":"🕪 ")+chn.name
            else
              option(value=chn.id id=chn.id)= (chn.type==0?"#":"🕪 ")+chn.name

mixin roleSelect(id,roles,defaulte)
  .plx-pink-input
      select(id=id name=id)
          each rol in roles.filter(r=>r.name!="@everyone").sort((a,b)=>a.position-b.position)
            if rol.id === defaulte
              option(style="color: #"+rol.color.toString(16) value=rol.id id=rol.id selected)= rol.name
            else
              option(style="color: #"+rol.color.toString(16) value=rol.id id=rol.id)= rol.name
              
