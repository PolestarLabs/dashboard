mixin feedItem(item)
    .plx-flex.feed-item
        div.img-container
            img(src=item.thumb || "https://s3.us-east-2.amazonaws.com/upload-icon/uploads/icons/png/5461146321553771552-512.png" ).feed-icon
        .plx-flex.plx-flex-column
            h4.title= item.name || "Unknown Feed" 
            .plx-flex.plx-flex-column
                //- TODO implement proper deleted channel handling
                code.mistyblue(style='background-color:white; border: none;')= "#"+(channelInfo.find(c=>c.id == item.channel) || { name: 'deleted-channel' }).name
                p
                    b Last: 
                    if item.last.link
                        a(href=item.last.link): i= item.last.title
                    else
                        i= item.last.title
                


+section( "Twitch Alerts",' ', "twitch",".fab.fa-twitch",null,true,"#3C26A6")
    each item in feeds.filter(feed=> feed.type == 'twitch')
        +feedItem(item)
                    
                 
        

+section( "YouTube Alerts",' ', "youtube",".fab.fa-youtube",null,true,"#F00")
    each item in feeds.filter(feed=> feed.type == 'youtube')
        +feedItem(item)
+section( "RSS Feeds",' ', "rss",".fas.fa-rss-square",null,true,"FF3C00")
    each item in feeds.filter(feed=> feed.type == 'rss')
        +feedItem(item)
 

