-
    helper=
        `
       Discord already introduces new members, but you can always make it better!
       Add a custom message to your new members, and optionally let me send a special image to introduce them~       

        `



+section("Reaction Roles","Let users pick a role by clicking a reaction","reactionroles",".far.fa-hand-point-up",helper,true)
    .plx-grid
        .plx-width-expand
            h4 This feature should be set up in Discord with the <code class="mistyblue">#{serverData.modules.PREFIX}reactionroles</code> command.
            h5 Check below the active Reaction Roles for this server
        .plx-width-1-1(class="plx-width-2-5@m")
            //p.helpe!= helper.replace('\n','<br>')
    include ../tools/twemoji
    include ../tools/invertcolor
    style .emoji{width:24px}
    style .emojirole{padding:.08rem .8rem; border-radius: 24px; margin:1rem}
    style .rearolecontainer{padding:1.5rem; border-radius: 8px; margin:1rem; border: solid 2px var(--accent-color); position:relative}
    .rearoles.plx-flex.plx-flex-wrap
        each rea in reactRoles
            - let channel = channelInfo.find(ch=>ch.id==rea.channel)
            if(channel)
                .rearolecontainer.plx-flex-none(id=rea.message)
                    button.del-rea-rol(plx-close data-channel=channel.id data-message=rea.message ).plx-close-large.plx-modal-close-default
                    p
 
                        span.title= "#"+ channel.name
                        br
                        b Message 
                        span.chanlink: a(href=`https://discordapp.com/channels/${serverInfo.id}/${channel.id}/${rea.message}` target='blank')= rea.message 
                    p
                        b Reactions
                    p
                        each r in rea.rolemoji
                            span 
                                if r.emoji.length > 5
                                    img(width="24px" src=`https://cdn.discordapp.com/emojis/${r.emoji.split(":").pop()}.${r.emoji.startsWith('a:')?"gif":"png"}`)
                                else
                                    -x= twemoji.parse(r.emoji)
                                    span!= x
    
                            -let role = roleInfo.find(ro=>r.role===ro.id)||{}
                            -let roleHexColor = "#"+(role.color||0xcccccc).toString(16);

                            span.emojirole(style=`color: ${invertcolor(roleHexColor,true)}AA; background-color: ${roleHexColor};`)= role.name
                            br
            else
                .rearolecontainer.plx-flex-none(id=rea.message)
                    button.del-rea-rol(plx-close data-channel=rea.channel data-message=rea.message ).plx-close-large.plx-modal-close-default
                    p Broken Entry 
                    p= rea.message
                    p= rea.channel







