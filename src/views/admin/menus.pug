mixin section(title,sub,id,icon,helper,noside,color)
    section.plx-flex.plx-flex-wrap.plx-card.plx-card-default.plx-card-body(id=id style=`margin-bottom:45px; z-index:${incremental--}` plx-scrollspy="cls: plx-animation-slide-left-small; repeat: true;delay:200" )
