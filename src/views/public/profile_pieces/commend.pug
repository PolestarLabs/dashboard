.commendInfo#upf
    
    div(v-if='commendRank.in.loading') 
    div(v-else)
        p Commend Ranking
        
        .plx-flex.commend-rank
            .pos(style="font-family: 'Panton Black';font-size:32 ")
                span.hashtag # 
                span.postext {{commendRank.in.rank}} 
            .count Count: {{commendRank.in.count}} 

    div(v-if='commendInfo.loading') 
        i.fas.fa-cog.fa-spin
    div(v-else ).commends-list

    
        .commens-in
            p Top Commenders
            a.de-link.commend.plx-animation-slide-top-small(
                :href='"/profile/"+cmd.id'
                v-for="(cmd,ind) in commendInfo.whoIn.slice(0,10)"
                :style="{'animation-delay': `${ind*.11}s` }"
            )                
                div.avatar
                    img(:src="udata(cmd).avatar ? udata(cmd).avatar.startsWith('https')?udata(cmd).avatar:`https://cdn.discordapp.com/avatars/${cmd.id}/${udata(cmd).avatar}.png` : 'https://cdn.discordapp.com/embed/avatars/0.png' " width='24px')
                    .commends 
                        span {{cmd.count}}
                        img(src= "https://upload.wikimedia.org/wikipedia/commons/3/3c/Fleur-de-lis-fill.svg" plx-svg).commend-token
                .username
                    span.name {{udata(cmd).username}}
                    span.discrimin
                        span {{udata(cmd).discriminator}}
                span.pos(style="font-family: 'Panton Black' ")
                    span.hashtag # 
                    span.postext {{ind+1}}


        .commens-out
            p Top Commended
            a.de-link.commend.plx-animation-slide-top-small(
                :href='"/profile/"+cmd.id'
                v-for="(cmd,ind) in commendInfo.whoOut.slice(0,10)"
                :style="{'animation-delay': `${ind*.11}s` }"
            )
                span.pos(style="font-family: 'Panton Black' ")
                    span.hashtag # 
                    span.postext {{ind+1}}
                .username
                    span.name {{udata(cmd).username}}
                    span.discrimin
                        span {{udata(cmd).discriminator}}
                div.avatar
                    .commends
                        span {{cmd.count}}
                        img(src= "https://upload.wikimedia.org/wikipedia/commons/3/3c/Fleur-de-lis-fill.svg" plx-svg).commend-token
                    img(:src="udata(cmd).avatar ? udata(cmd).avatar.startsWith('https')?udata(cmd).avatar:`https://cdn.discordapp.com/avatars/${cmd.id}/${udata(cmd).avatar}.png` : 'https://cdn.discordapp.com/embed/avatars/0.png' " width='24px')