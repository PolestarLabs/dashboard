extends ../../layout 

mixin craftSlot(item)
  .item-container.filled.bgcolor(v-if=item @click="removeFromPot("+item+")", :class=item+".rarity", @contextmenu.prevent="removeFromPot("+item+",true)") 
    .item-img(:style="`background:url(/build/items/${("+item+"||{}).icon||("+item+"||{}).id}.png)`")
    .item-name {{#{item}.id}}
    .count-badge {{#{item}.count}}
  .item-container.empty(v-else)
    .item-img
    .item-name ---
    .count-badge 0

block head
  script(src="https://cdnjs.cloudflare.com/ajax/libs/vue/2.6.14/vue.common.dev.min.js")
  link(rel='stylesheet' href="/css/supersplash.css")
block content

  include ../../navbar
  style 
    include workshop.css
  script(src="https://cdnjs.cloudflare.com/ajax/libs/vue/2.6.14/vue.common.dev.min.js")

  section.supersplash( plx-parallax="bgy:-200;media: @m")
    svg(plx-scrollspy="cls:plx-animation-slide-left-medium; delay: 1s")#curve-1(version='1.1' xmlns='http://www.w3.org/2000/svg' xmlns:xlink='http://www.w3.org/1999/xlink' x='0px' y='0px' viewBox='0 0 1366 768' style='enable-background:new 0 0 1366 768;' xml:space='preserve')
      g
        polygon.st0(points='981.8,0 1442,0 1059,768 554,768 	')
    svg(plx-scrollspy="cls:plx-animation-slide-bottom; delay: 2s")#curve-2(version='1.1' xmlns='http://www.w3.org/2000/svg' xmlns:xlink='http://www.w3.org/1999/xlink' x='0px' y='0px' viewBox='0 0 1366 768' style='enable-background:new 0 0 1366 768;' xml:space='preserve')
      g
        path.st1(d='M1366,433c0,132,0,151,0,151v184c0,0-1289,0-1366,0c0-41,0-155,0-155S698,768,1366,433z')
    .plx-container.central-container.plx-flex

      .decor-block-1
      .decor-block-2
      .plx-width-1-2.main-info
          h1(style="margin: 125px -250px 50px 0;").title.stfront Crafting Workshop
          h3.subtitle Mix, Explore, Discover! 
          p 
              | Pollux has many items for you to use and do fun things with them. Here you can craft the basic material items that you might need as well as create entirely new items out of the ones you have!
              br
              | Use the discovery section to put some of your items and materials together and see what new things you can come up with!
          br
          br
          .plx-flex.icons-row(plx-scrollspy="target: > a; cls: plx-animation-fade; delay: 100")
              a.plx-width-1-3.icon-container(href="#basic" plx-scrollspy-class="plx-animation-slide-right-small" plx-scroll="offset:85").hero-icon
                  .icon: img(src="/images/craft1.png" width=120 height=120).pop
                  .textcont(class="plx-visible@m")
                    .title.textcont.stkpak   Basic stuff for beginners!
                    .title.textcont.stkname Items & Materials  
                  .title.mobile(class="plx-hidden@s")  Items & Materials  
                  
              a.plx-width-1-3.icon-container(href="#discovery" plx-scrollspy-class="plx-animation-slide-top-small" plx-scroll="offset:85").hero-icon
                  .icon: img(src="/images/craft3.png" width=120 height=120).pop
                  .textcont(class="plx-visible@m")
                    .title.textcont.stkpak   How about something new?
                    .title.textcont.stkname Discovery Crafting
                  .title.mobile(class="plx-hidden@s")  Discovery Crafting
              a.plx-width-1-3.icon-container(href="#advanced" plx-scrollspy-class="plx-animation-slide-left-small" plx-scroll="offset:85").hero-icon
                  .icon: img(src="/images/craft2.png" width=120 height=120).pop
                  .textcont(class="plx-visible@m")
                    .title.textcont.stkpak   For veteran artisans!
                    .title.textcont.stkname Specialised Crafting
                  .title.mobile(class="plx-hidden@s")  Specialised Crafting
          //.plx-flex.main-button
              a.magic-outline.plx-button.plx-margin-left.plx-margin-bottom(type='button' href="#storetop" plx-scroll)
                  span See Store Listings
          //.plx-flex.minifooter
              .icon 1
              .icon 2
              .icon 3
              .icon 4

      .plx-width-1-2.bigpic-container(plx-scrollspy="cls:plx-animation-slide-right-medium; delay: 2s")
          .bigpic: img(src="/images/pollux/plx_craft_800x600.png"  plx-parallax="y:200;media: @m")

    .bottom-board
        p board stuff goes here



  br
  br
  br
  section#basic
    .plx-container

      h1.title Basic Items & Materials
      h2.subtitle The best way to start

      p
        | Some items are very basic and you might need them a lot. Below you can find a few of these basic items and craft them as you need.
      br
      hr.plx-divider-icon
      h2 Basic items catalog is coming soon!
      h3 This section is unavailable during beta. Check back later!

    .plx-uncontainer
      include basic_items
      br

  br
  hr
  br
  section#discovery
    .plx-container

      h1.title Discovery Crafting
      h2.subtitle Mix and try items together

      p
        | Click the items from your inventory to add them to the crafting panel and vice-versa.
        br
        | Right click to send all items from one panel to the other. Share your discoveries with your friends!
        br
        | Crafting items grant you a bit of Crafting EXP bonus. Every new discovery gives you Progression EXP bonus, you can revisit things you've crafted before in your <b>Craftbook</b>. The higher your crafting level is, more items are available for discovery!

      hr.plx-divider-icon
      br
    br

    #crafting.plx-flex.plx-position-relative
      .crafting-zone
        .crafting-happening
          svg.energy-bar(:class='craftingNow?"animating-craft":"" ')
            circle(cy="50%" cx="50%" r=250).trail
            circle(cy="50%" cx="50%" r=250 v-bind:class = "potLevel()" )
        
          .crafting-table.spinCW(:class='craftingNow?"animating-craft":"" ')
            .table-contents.plx-flex.plx-flex-around
              .slot1: .spinCCW(:class='craftingNow?"animating-craft":"" ')
                +craftSlot("pot[0]")
              .slot2: .spinCCW(:class='craftingNow?"animating-craft":"" ')
                +craftSlot("pot[1]")
              .slot3: .spinCCW(:class='craftingNow?"animating-craft":"" ')
                +craftSlot("pot[2]")
            .gemcraft(v-if="discovery.discovery && discovery.discovery.gemcraft")
              .gem.rubines( 
                v-bind:style="{opacity: Math.max(.5,discovery.discovery.gemcraft.RBN ||0)}",
                :class="cantRBN?'cannotPay':''"
              ): .spinCCW(:class='craftingNow?"animating-craft":"" ')
                .icon
                .cost {{discovery.discovery.gemcraft.RBN}}

              .gem.jades(  
                v-bind:style="{opacity: Math.max(.5,discovery.discovery.gemcraft.JDE ||0)}",
                :class="cantJDE?'cannotPay':''"
              ): .spinCCW(:class='craftingNow?"animating-craft":"" ')
                .icon
                .cost {{discovery.discovery.gemcraft.JDE}}

              .gem.sapphires( 
                v-bind:style="{opacity: Math.max(.5,discovery.discovery.gemcraft.SPH ||0)}",
                :class="cantSPH?'cannotPay':''"
              ): .spinCCW(:class='craftingNow?"animating-craft":"" ')
                .icon
                .cost {{discovery.discovery.gemcraft.SPH}}


        .discovery 
          div(v-if="discovery.loading")
            p LOADING...
          div(v-if="discovery.loading === false || !pot.length")
            p add items to the table
          .discovery-item(v-else)
            p(v-if="discovery.possible") {{ discovery.possible }} possible items. 
              span(v-if="discovery.noMoreTable") You just need more of what you already have.
              span(v-else) Add more items to the table!

            p(v-if="discovery.possible === 0") No items can be made out of this, try removing some items or try different items.
            .discovery-item(v-if="discovery.discovery")
              .item-container.bgcolor(:class="discovery.discovery.rarity")
                .item-img(
                  :style="`background:url(/build/items/${discovery.discovery.icon}.png)`",
                  :class="discovery.isDiscovery ? '' : 'revealed'"
                )
                .item-name(v-if="discovery.isDiscovery") {{ discovery.discovery.name.replace(/[A-z,0-9]/g, '?') }}
                .item-name(v-else) {{ discovery.discovery.name }}
              p(v-if="discovery.canCraftNow") Can be crafted now!
                button.craft-me(@click="craft()" :disabled="!canCraft()") CRAFT

      .inventory
        .items-list(v-if="!userdata")
          p You need to be logged in to see your inventory here!
          br
          a.magic-outline.plx-button.plx-margin-left.plx-margin-bottom(type='button' onclick="login()") LOGIN
        .items-list(v-else-if="inventory.loading")
          p LOADING....
        .items-list(v-else)
          p Items: {{ inventory.length }}
          ul.items
            li.inv-item(v-for="item in inventory")
              .item-container.bgcolor(
                @click="addToPot(item)",
                @contextmenu.prevent="addToPot(item, true)",
                :class="[(item.meta||{}).rarity, item.count === 0 ? 'nomore' : '', item.new ? 'isnew' : '']"
              )
                .item-img(
                  :style="`background:url(/build/items/${(item.meta||{}).icon || item.id}.png)`"
                )
                .item-name {{ (item.meta||{}).name || item.id }}
                .count-badge {{ item.count }}
        br
        .tutorial(class="plx-visible@m")
          .plx-flex.plx-flex-around
            .lmb
              .icon: include ../../../public/cur/mouse.svg
              span.txt Add/Remove 1 item
            .rmb
              .icon: include ../../../public/cur/mouse.svg
              span.txt Add/Remove All items

  hr
  section#advanced
    .plx-container
      h1.title Advanced Crafting
      h2.subtitle Make an income from crafting fancier items
      hr.plx-divider-icon

      h2 Advanced Crafting is coming soon!
      h3 This section is unavailable during beta. Check back later!
      br
      br
      br
      br
    hr



block scripts
  script
    include workshop.js