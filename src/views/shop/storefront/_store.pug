                      a.plx-button(href="#storetop" plx-scroll="offset:30")
                          i: .fas.fa-cubes
                          label  Bundles
                  li.megastroke.menuitem(plx-filter-control="filter: .medal ; group: type" )
                      a.plx-button(href="#storetop" plx-scroll="offset:30")
                          i: .fas.fa-images
                          label  Backgrounds
