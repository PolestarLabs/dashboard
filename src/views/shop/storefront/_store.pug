                      a.plx-button(href="#storetop" plx-scroll="offset:30")
                          i: .fas.fa-store
                          label  Marketplace
                  li.megastroke.menuitem(plx-filter-control="filter: .item ; group: type" ).plx-disabled
                      a.plx-button(href="#storetop" plx-scroll="offset:30")
