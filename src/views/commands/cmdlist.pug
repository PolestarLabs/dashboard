extends ../layout 
block head
    link(rel="stylesheet" href="/css/commands.css")
block content

    .wrapper
        -currentPage = 'commands'
        include ../navbar

        style
            include commands.css

        - let r = Math.floor(Math.random() * (1 - 0 + 1) + 0);
        .plx-background-cover(plx-parallax="bgy: 100,400" style='background-image: url(/images/heads/office'+r+'.png)').pictoheader.dark
            .plx-container
                br
                h1.title Command List
                h3.subtitle All available commands and more
                hr.plx-divider-small

        hr.plx-divider-icon-fill
        .plx-container
            .section#main    
                h2 
                h4.subtitle 
                p
                hr.plx-divider

            .section                
                small.help Commands Description Language
                mixin langButton(code,flag,badge)
                    a.button.is-small.active(id=code)
                        img(src="/build/guessing/guessflags/"+flag+".png")
                        if badge=="HQ"
                            .badge(plx-tooltip="High Quality Translation")
                                i: .fas.fa-star
                        if badge=="SRC"
                            .badge(plx-tooltip="Source Language")
                                i: .fas.fa-code
                        if badge=="SOON"
                            .badge(plx-tooltip="Coming Soon")
                                i: .fas.fa-clock
                        if badge=="NEW"
                            .badge(plx-tooltip="Newly Added")
                                i: .fas.fa-meteor
                        if badge=="HLP"
                            a.badge(href="https://crowdin.com/project/pollux" plx-tooltip="Translators Needed!")
                                i: .fas.fa-life-ring

                .plx-flex.plx-flex-around.flag-icons
                    +langButton('dev','united-states','SRC')                        
                    +langButton("de","germany")
                    +langButton("cs","czech-republic")
                    +langButton("pt-BR","brazil", "HQ")
                    +langButton("es-ES","spain", "HQ")
                    +langButton("fr","france")
                    +langButton("ro","romania")
                    +langButton("hu","hungary")
                    +langButton("pl","poland", "HQ")
                    +langButton("bg","bulgaria")
                    +langButton("by","belarus")
                    +langButton("ru","russia","HLP")
                    +langButton("ua","ukraine")
                    +langButton("tr","turkey", "HQ")
                    +langButton("zh-TW","taiwan")
                    +langButton("ko","south-korea")
                    +langButton("ja","japan")
                    +langButton("vi","vietnam","SOON")
                    +langButton("ar","saudi-arabia","SOON")

                .commandTable                                   
                    
                    
                    div(plx-filter="target: .commandFilter")
                        small.help Category Filter
                        
                        ul.plx-subnav.plx-subnav-pill.subnavite
                            li(plx-filter-control="")#allFIlter: a All
                            each cat in cm.CATS.filter(x=>(x.name||"").toLowerCase() !== "nsfw")
                                li(plx-filter-control=".filter-"+cat.consolidated).genericFilter: a(class="c-outline "+cat.consolidated)=  cat.name
                        
                        
                        .plx-grid.commandStream
                            .plx-width-1-1(class="plx-width-3-4@s")
                                .commandFilter#commands-dock.compactable
                                    
                                    //include cmd_element a
                                    
            
                            .plx-width-1-4.weirdSidebar
                                ul#weirdNav.plx-flex-column.plx-subnav.plx-subnav-pill( style="z-index: 1; margin-left:0" plx-sticky="bottom: true; offset: 80" plx-scrollspy-nav=" closest: li; scroll: true; offset: 100;" )
                                    .plx-button(type='button' plx-toggle="target: .compactable; cls: compact" ).compactable COMPACT MODE
                                    a(href="#top").plx-button
                                        i: .fas.fa-arrow-up
                                        | TOP
                                    each cat in cm.CATS.filter(x=>(x.name||"").toLowerCase() !== "nsfw")
                                        li(): a(href="#"+cat.consolidated)=  cat.name                                                 


                                
                                //.commandName= cmd.name
                                    span.plx-label.plx-align-right= cmd.cat
                                    div
                                            p.lh-1: i!= sanitise(cmd.desc)
                                            .plx-flex(plx-grid)
                                                .plx-width-3-4.plx-text-meta.plx-text-small.lh1
                                                    p!= sanitise(cmd.use)
                                                //.plx-width-1-4
                                                    each ali in cmd.aliases
                                                        span.plx-label.plx-label-danger= ali
                                                        |&#x2003

                                    hr
                                    each pe in cmd.perms||[]
                                        if pe!="SEND_MESSAGES"
                                            span.plx-label.bg-discord: i= pe.replace("_"," ")
                                            |&#x2000
              
            


                br#end
                hr.plx-divider-icon
            //pre=JSON.stringify(cm,0,3)
            


block scripts
    script var LOCALE = "#{locale||lang}"
    script
        include cmdscripts.js
    script.
        $('.button').click(function(){
            $('.flag-icons a').removeClass('active')
             setLang(this.id)
            $(this).addClass('active')
        })