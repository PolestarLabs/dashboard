{
  "name": "pollux-core-api",
  "version": "0.1.0",
  "private": true,
  "description": "Pollux REST API — ElysiaJS on Bun. Lives alongside the Express dashboard during migration; will be extracted to its own repo in Phase 5.",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run postinstall && bun run src/index.ts",
    "typecheck": "bun tsc --noEmit",
    "postinstall": "node node_modules/skia-canvas/lib/prebuild.mjs download --or-compile"

  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.3",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.0",
    "@elysiajs/server-timing": "^1.4.0",
    "@elysiajs/swagger": "^1.3.1",
    "@polestar/database_schema": "github:PolestarLabs/db-schema",
    "elysia": "^1.4.25",
    "ioredis": "^5.9.3",
    "mongoose": "^8.23.0",
    "skia-canvas": "^3.0.8",
    "stackblur-canvas": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "typescript": "^5.9.3"
  }
}
