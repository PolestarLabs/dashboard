# Copy to .env and fill in. Never commit .env.
# Used when running the API from the api/ directory (e.g. bun run start).

# MongoDB — required. For local dev use a direct URL (localhost or docker host).
# MONGO_URL, MONGODB_URL, or DB_INFO (dashboard root) are read.
# Local: mongodb://localhost:27017/pollux  (or mongodb://mongo:27017/pollux if API runs in Docker)
# Prod:  mongodb+srv://user:pass@cluster.mongodb.net/pollux (must be reachable from API host)
MONGO_URL=mongodb://localhost:27017/pollux

# Redis (optional)
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# API server
# API_PORT=7056

# Dashboard Discord OAuth (for /auth/discord, /auth/callback, /auth/me)
# Get these from Discord Developer Portal → your app → OAuth2.
# Discord only allows HTTPS redirect URIs. Redirect in Discord = {API_PUBLIC_URL}/auth/callback
# Local dev: use an HTTPS tunnel (ngrok, cloudflared) for API_PUBLIC_URL, or AUTH_DEV_SECRET (see AUTH.md).
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
API_PUBLIC_URL=
# Optional: dev-only fake session (NODE_ENV != production). Set to a secret; then GET /auth/dev-session?secret=...&uid=DISCORD_USER_ID&redirect_uri=...
# AUTH_DEV_SECRET=

# Bot token (for Discord API user lookups; can reuse a bot from dashboard CLIENT)
# BOT_TOKEN=
