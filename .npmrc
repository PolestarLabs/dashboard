engine-strict=true
fetch-retries=1
fetch-retry-maxtimeout=8000
fetch-retry-mintimeout=0
fetch-retry-factor=1
ignore-scripts=false

# GitHub Package Registry for @polestarlabs (optional – only needed if you still pull private packages)
@polestarlabs:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
# use GH_TOKEN for local installs

