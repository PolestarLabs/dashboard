extends layout
block content
    include navbar
    style
        include home.css

    #bgHex
        .container( plx-parallax="x: 0,0; y: -10,30;viewport: .7;target: #start")
            video(autoplay loop muted playsinline  plx-parallax=" y: 0,50; target: body")
                source(src="/video/polluxhexaback.webm" type="video/webm")
    .plx-uncontainer 
            .splash_container( plx-parallax="opacity: 1,1; y:0,-100;vi6ewport: .5;tyarget: #start")
                div( plx-parallax="   y: 30,-250;xviewport: 1;target: body")
                    img(plx-img data-src="/images/pollux/idpollux_right_s2_dark.png" alt="Pollux Artwork by @arion910 and @dasFlicksie")#splash.plx-animation-plx
                //img(src="https://via.placeholder.com/600x800").splash
    #t
    .plx-container 
        section#top.plx-animation-plx
            //h1.title.plx-text-bold Pollux
            img(style="min-width: 300px; width: 55%;margin: 10px 30px 40px 20px;" src="/images/pollux_typ.svg" plx-parallax="opacity:1,0; y: 10,250")
            h2.subtitle( plx-parallax="opacity:1,0;y: 0,250;") A fancy maid for fancy places
    #content-roll
        .plx-uncontainer
            section#start.colorblock: .plx-container 
