+section("Global Command Switch ","   ","switches",".fas.fa-tasks",null,true)
    +pinkSwitch("respond-disabled","Respond to Disabled commands with a message",serverData.modules.respondDisabled || true)
    .help Otherwise, disabled commands will be ticked with a "X" reaction. <b>There's no "NO FEEDBACK" option.</b>
    ul(plx-accordion="multiple: true").categs-container
        each cat in commands.CATS
             li.categ(id=cat.consolidated)
                - let commandsFromThisCat= commands.CMS.collection.filter(c=>!c.hidden&&c.cat===cat.consolidated)
                - let code= !serverData.modules.DISABLED.includes(cat.consolidated) && !serverData.modules.DISABLED.every(disa=> commandsFromThisCat.some(cmd=> cmd.name === disa) )
                .plx-magic-input
                    .plx-pink-check
                        -let id= "global-cmd-cat-"+cat.consolidated
                        input.markall(data-cat=cat.consolidated type="checkbox" id=id name=id checked= code )
                        label(for=id)
                
                a.plx-accordion-title
                        h5.title= cat.name
                        .help= cat.description
                .plx-accordion-content
                    .container
                        each cmd in commandsFromThisCat
                            label.a-comand(class="cat_"+cat.consolidated)
                                input.command-toggle(type="checkbox" name=cmd.name checked=!serverData.modules.DISABLED.includes(cmd.name)&&!serverData.modules.DISABLED.includes(cmd.cat) )
                                span(plx-tooltip=cmd.desc)= cmd.name
                            
