                +pinkInput("server-prefix","Local Prefix for this Server","text",serverData.modules.PREFIX || "+","PREFIX") 
        .plx-flex-end.plx-width-1-1(class="plx-width-1-2@m")
            +pinkSwitch("global-prefix-toggle","Enable Global Prefix",serverData.globalPrefix||true)
            





-
    helper=
        `Global Language affects every channel that doesn't have a defined language, by default every channel will use the Global Language
        If you believe the translations are not quite right, or if there's a missing language you'd like to see, please <a href="https://translation.pollux.fun" target="blank">request access to translations</a> then join my Server and ask to become a translator.
        `
+section("Language","The language I'll speak on this server","language",".fas.fa-language",helper)
