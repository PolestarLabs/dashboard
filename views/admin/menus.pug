style hr:not(.plx-divider-small):not(.plx-divider-icon){opacity:.1}
-incremental = 100
mixin section(title,sub,id,icon,helper,noside)
    section.plx-flex.plx-flex-wrap.plx-card.plx-card-default.plx-card-body(id=id style=`margin-bottom:45px; z-index:${incremental--}` plx-scrollspy="cls: plx-animation-slide-left-small; repeat: true;delay:200" )
        .plx-width-expand
            h3.title
                i.icon: div(style="opacity:.8" class=icon.split('.').join(' '))
                span &#x2004 #{title}
            h5.subtitle!= sub
            //br
            block             
            br
        if(!noside)
            .plx-width-1-1(class="plx-width-1-5@l plx-width-2-5@xl")
                p.helpe!= helper.replace('\n','<br>')
