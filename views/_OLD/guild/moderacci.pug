-
  let save_mod_button = {
    theme:'is-ruby savmod_button',
    classes:'fas fa-save',
    colA: '#ccc',
    colB: '#aaa',
    caption: 'SAVE',
    id: 'save_mod'
    }
  let gotoAdvan = {
    theme:'is-purple gotoAdvan',
    classes:'fas fa-cogs',
    colA: '#ccc',
    colB: '#aaa',
    caption: 'Configure Logs',
    id: "gotoAdvan",
    href:'#/logs'
    }
            




.nano: .nano-content.padded(style="padding-right:55px")
  .columns
    .column.is-10
      .title.is-2: b Moderation
      p.subtitle Deeper Administrative Settings for more serious needs
    .column.is-2
      +iconButton(save_mod_button)
  hr
  .columns
    //SPAM BUSTER-------------------------------------
    .column
      .title
        i.icon: .fas.fa-crosshairs 
        span &#x2004 Spam Buster
      p.subtitle.is-5 Experimental Supermodule: Snipes misbehaving members
      br 
      -let item;
      -let bypass;
      -let BUSTER = server.modules.BUSTER;
      -let byhelp = 'This role will be ignored for this filter'
      .padding-25
        .title.is-5
          i.icon: .fas.fa-at
          span &#x2004 Anti Mention Spam
        p.subtitle.is-7 Snipe users that mentions too much
        -item   = BUSTER && BUSTER.switches.mentionSpam 
        -bypass = BUSTER && BUSTER.bypass.mentionSpam      
        +checkLine1(item,"mention")
        p Bypass Role
        +rolelist('mention_bypass',bypass,byhelp)
        hr
        .title.is-5
          i.icon: .fas.fa-unlink
          span &#x2004 Anti Link
        p.subtitle.is-7 Snipe messages containing links
        -item = BUSTER && BUSTER.switches.links 
        -bypass = BUSTER && BUSTER.bypass.links  
        +checkLine1(item,"links")
        p Bypass Role
        +rolelist('link_bypass',bypass,bypass,byhelp)
        br
        p Whitelist
        textarea.textarea(placeholder=BUSTER.params.links.join(', ')||"Insert Domains that will be ignored, one per line.")#link_filter
        p.help Insert Link <b>Domains</b> that will be ignored, one per line.
        .help Example: gyazo.com

        hr

        .title.is-5
          i.icon: .fas.fa-sign-in-alt 
          span &#x2004 Anti Invite
        p.subtitle.is-7 Snipe messages containing Invite Links
        -item = BUSTER && BUSTER.switches.invites 
        -bypass = BUSTER && BUSTER.bypass.invites  
        +checkLine1(item,"invites")
        p Bypass Role
        +rolelist('invite_bypass',bypass,bypass,byhelp)
        br
        p Whitelist
        textarea.textarea(placeholder=BUSTER.params.invites.join(', ')||"Insert Invite Codes that will be ignored, one per line.")#invite_filter
        p.help Insert Invite <b>Codes</b> that will be ignored, one per line.
        .help Example: yxYMjp5

      hr
      .title
        i.icon: .fas.fa-filter 
        span &#x2004 Word Filter
      p.subtitle.is-5 Snipe banned words
      br
      -item = BUSTER && BUSTER.bypass.words  
      -bypass = BUSTER && BUSTER.bypass.words  
      +checkLine1(item,"words")
      p Bypass Role
      +rolelist('words_bypass',bypass,bypass,byhelp)
      br
      p Blacklist
      textarea.textarea(placeholder=BUSTER.params.words.join(', ')||"Insert Words that will be filtered, comma-sepparated.")#words_filter
      p.help Insert <b>Words</b> that will be filtered, comma-sepparated.
      .help Example: fuck,shit,cock,dick
    hr

    
    //LOG-------------------------------------
    .column
      .title
        i.icon: .fas.fa-th-list 
        span &#x2004 Logs
      p.subtitle.is-5 Be aware of <b>every</b> activity around
      br
      -let logging = server.logging
      -let split = server.splitLogs
      .boxa
          .level.is-marginless
            label.switch.level-left              
              input(type="checkbox" data-type="logON" checked=logging).check.logstoggle#checklf
              span.slider.lite
              
            p.subtitle.is-marginless.level-left: b &#x2003 Log Server Activity
            br
            span &#x2003
            .level-right
              .button.itm(data-target="logs").is-dark.is-small#cfgLogs=translation.website.configure || "Configure"
          -let logsEnabled =  logging?"":"display:none;"
          .logset(style=logsEnabled)
            br
            p.help Choose the Channel to Log things on, you can split logs through different channels
            .columns
              .column
                br


                p=translation.website.all_logs || "All Logs"

                .field.has-addons.level
                  div.control.level-left: .select.is-small: select( disabled= split ).unadvanced#logcha
                    each chan in svChannels
                      if chan.id == server.modules.LOGCHANNEL
                        option(id=chan.id selected)= chan.name
                      else
                        option(id=chan.id)= chan.name

                li.level
                    label.switch.level-left

                      input(type="checkbox" data-type="logSPLIT" checked=split).check.advtog#splitchk
                      span.slider.lite
                    span &#x2003
                    p.level-left.is-marginless= translation.website.split_logs ||  "Split Logs"
                    .level-item

                br
                +iconButton(gotoAdvan)
                br

              .column.advanced(style=logsEnabled2)
                p=translation.website.advanced || "Advanced"
                .field.has-addons.level
                  div.control.level-left: .select.is-small: select( disabled=!split )#logchaAD.advanced
                    each chan in svChannels
                      if chan.id == server.modules.ADVLOG
                        option(id=chan.id selected)= chan.name
                      else
                        option(id=chan.id)= chan.name


                p=translation.website.activity || "Activity"
                .field.has-addons.level
                  div.control.level-left: .select.is-small: select( disabled=!split )#logchaAC.advanced
                    each chan in svChannels
                      if chan.id == server.modules.ACTLOG
                        option(id=chan.id selected)= chan.name
                      else
                        option(id=chan.id)= chan.name


                p=translation.website.moderation || "Moderation"
                .field.has-addons.level
                  div.control.level-left: .select.is-small: select( disabled=!split )#logchaMD.advanced
                    each chan in svChannels
                      if chan.id == server.modules.MODLOG
                        option(id=chan.id selected)= chan.name
                      else
                        option(id=chan.id)= chan.name              

      hr
  
      .title
        i.icon: .fas.fa-terminal
        span &#x2004 Muted Members
      p.subtitle.is-5 Track Members that are currently Muted
      br
      //-let exps = []
      //each muted,i in muteds
        if muted
          .level
            -let GUY = muted
            -let avi = GUY.avi||(GUY.meta||{avatar:''}).avatar
            .level-left
              img(src=avi width='50px').is-round
              p: b= GUY.tag||(GUY.meta||{tag:GUY.name}).tag
            .level-item
            .level-right
              span Mute expires:&#x2003;
              b: span.mome= exps[i]

      
      
      hr
  
  hr
  +iconButton(save_mod_button)
  br
    
    
script(src="/js/guilds.js")
script(src="/js/moment.js")
script.
  $('.mome').each(function(){  
    var x=Number($(this).html())
    if(isNaN(x))x="Undetermined";
    else x = moment(x).format("MMM Do hh:mm a");
    $(this).html(x)
  })

   