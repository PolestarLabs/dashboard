
style.

  @media screen and (max-height:750px){
    .ov{
     // transform:scale(.9) translateY(-20px);
      position:relative;
    }
  }
  .ov{
      width:
      border: solid 2px #0b0b0b;
  }
  .bbgColor{

  height:100%;
  width:25px;
  position:absolute;
    top:0;
    opacity:.8;
  left:0;
  z-index:1
  }
  .bbg{
  background-size:100%;
  filter:blur(5px);
  height:100%;
  width:100%;
  top:0;
  left:0;
  position:absolute;
  z-index:0;

  }

  .ovi{
 // width:30%
  }
  .upfront{
  z-index:21;
  position: relative;
  }
  .bbgOvlay{

  top:0;
  left:0;
  position:absolute;
  background: linear-gradient(70deg, #111 0%,#1e1e1e 37%,rgba(0, 0, 0, 0) 100%);
  height:100%;
  width:100%;
  z-index:1;
  }
  @media screen and (max-width:800px){
    .medhoist{
      transform:scale(.7) translate(-84px,-120px)
    }
      .bbg {
        filter:none;
        position:fixed;
      } 
      .bbg img {
        height:auto !important;
        width:100% !important;
      }
