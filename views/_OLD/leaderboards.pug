extends layout

block nav
    include templates
 
    -let rankupdate = rank
    
    .hero.is-primary.is-bold 
      include navbas
      .level.is-hidden-mobile
            .level-item

            .level-left
                div
                  p.title: b Leaderboards
            .level-item
                p.subtitle Global EXP Ranking
                
            .level-item
            .level-item
            
      br
                 

mixin ranke(table,idd)
          table.ranktable(id=idd)
                thead.rhead.is-hidden
                  th(class="anim:position") 
                  th(class="anim:constant")
                  th(class="anim:id") 
                  th(class="anim:constant")
                  th(class="anim:update anim:constant") 
                  th(class="anim:constant") 
                  th(class="anim:constant") 
                tbody
                  -table.pop()
                  -table.pop()
    


        
                  each guy, i in table
                    
                    x
                      -let rk = 0
                      - 
                          switch (i){
                            case 0:
                              rk= 1;
                              break;
                            case 1:
                              rk= 2;
                              break;
                            case 2:
                              rk= 3;
                              break;
                            default:
                              rk= 0;
                              break;
                            }
                      
                      if userinfo
                      
                        -var thatsMe = userinfo.id
                      else 
                        -var thatsMe = null
                      
                      -let ka
                    
                      -thatsMe == guy.id ? ka="kali" : ka="";  
                      if(!(guy.id == "271394014358405121" ||guy.id == "88120564400553984" || guy.id == "354285599588483082"))
                        tr(class="num"+rk+" "+(ka) id="gee"+(i+1))
                          td.b900.position= i+1


                          td: div.l100
                            .hexagon(style="background-image:url('"+guy.avi+"');")
                              .hexTop
                              .hexBottom
                          td.nae
                            a(href='/profile/'+guy.id)
                              //!{guy}
                              span: b= guy.name.split("#")[0] || guy.name
                              span.discr= "#"+(guy.name.split("#")[1]||"?")

                          td.lvl
                            .attop
                              span.b500 Level 
                              span= guy.lv

                          td.exp
                            p
                              span.countup(data-count= guy.exp) 0
                              span.b500= "exp" 
                          td.rubine.is-hidden-mobile
                            p
                              span &#x2003
                              span= guy.rubine
                              span &#x2003
                              span: img(src='/images/rubine.png' width="16px")
  
     
                            
                          

                        
block content
  style.
    .problock{
      position: absolute;
      right:-20px;
      margin:-14px;
    }

  .nano: .nano-content: .container#xd
    br
    //pre= JSON.stringify(rank)
    +ranke(rank,"first")
                      


block scripts
  script(src="/js/tabkle.js")
  script(src="/js/countUp.js")
  script.
        var options = {
        useEasing: true,
        useGrouping: true,
        separator: '.',
        decimal: '.',
        };

        function count(){

        $.each($('.countup'), function (X) {
        var count = $(this).data("count"),
        st = $(this).data("start") || 0,
        t = $(this).data("time") || 0,
        off = $(this).data("offset") || 0,
        numAnim = new CountUp(this, st, count, 0,t,options);
        setTimeout(function(){

        numAnim.start();
        },X*180-off)
        });
        }
        count()
        var anim= {
                  up: {
                      left: 0,
                      backgroundColor: "inherit !important"
                  },
                  down: {
                      left: 0,
                      backgroundColor: "inherit !important"
                  },
                  fresh: {
                      left: 0,
                      backgroundColor: "inherit !important"
                  },
                  drop: {
                      left: 0,
                      backgroundColor: "inherit !important"
                  }
              }
              
              var inter = setInterval(function(){
                update()
              },3000)
              setTimeout(function(){
               clearInterval(inter)
              },180000)
      function update(){
      $(".kali").removeClass("kali") 
        $.post(`./rk`, function (data) {
     
          $('#xd').append(data);
      
      $("#first").rankingTableUpdate(("#updated"),{
              duration: [1000,200,700,200,1000],
              onComplete: function(){
                  updating = true;
                  //change update status if required...
              },
                animationSettings: anim
          });
        });
          $("#updated").attr("id","first");

          $("#updated").remove()
      }

      
