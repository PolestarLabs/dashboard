block head
  link(rel='stylesheet',type="text/css" href='/css/newdash.css')
block content


  -let bgInv = user.modules.bgInventory

  //pre= JSON.stringify(user,null,5)
  .hero.is-primary.is-bold
      include navbas

      //.level.topbar.is-hidden-mobile
            .level-left
              //img(src=userinfo.pix).image(height="128px")
              div: .floatnglow: .hexagon(style="transform:scale(1.2) translate(20px,40px);background-image:url('"+userinfo.pix+"');")
                div.hexTop
                div.hexBottom
            div &#x2003
            div &#x2003
            div &#x2003
            div &#x2003
            .level-left
                div
                  p.title: b= userinfo.uname
                  p.subtitle= userinfo.name
            .level-item
                p(class="subtitle")!= "<b>ID </b>"+userinfo.id
            .level-item
            .level-item
      
  
  mixin menu
    .minitag
      .level.is-marginless.is-mobile
        .level-left
          .pic: .smolHex(style="transform:scale(.8);background-image:url('"+userinfo.pix+"');")
            .shexTop
            .shexBottom
        .level-item
        .level-item
          .title.is-4= userinfo.name
        .level-item
      p.uid= userinfo.id
      
    .menu-label Social
    ul.menu-list
        li#a1.itm2.dswitch.is-active(data-target="publicProfile"): a(href="#/overview") Public Profile
        //li#a4.itm2.tab(data-target="soon").is-hidden-mobile: a(href="#/inventory")=translation.website.inventory||  "Inventory"
    .menu-label Cosmetics
    ul.menu-list
        li#a2.itm2.dswitch(data-target="mdl"): a(href="#/medals") Medals
        li#a3.itm2.dswitch(data-target="bgs"): a(href="#/backgrounds") Backgrounds
        //li#a4.itm2.dswitch(data-target="ptx").is-hidden-mobile: a(href="#/persotex") Personal Text
        li#a5.itm2.dswitch(data-target="stk"): a(href="#/stickers") Stickers
    .menu-label Management
    ul.menu-list
        li#a6.itm2.dswitch(data-target="guildsets"): a(href="#/servers") My Servers
        
        
  .is-hidden-desktop
    .sidepanel-bg.hidden
    .sidepanel
      +menu
    a.sidemenu.button
      i.fas.fa-caret-square-down
      .b500
        span &#x2003
        span#loc MENU
  
  

  .container.preloder
        style
          include hearty 
          div.grid-big 
            - for (i=0; i<25; i++)
              div.cell-1
        br
        br
        p.title LOADING
  .dashy
      aside.sidebar.is-hidden-mobile
        +menu
      .mainview.prelod
          #publicProfile.switchPanel.fullwidth.fullheight.hidden
            //embed.profileme(src="http://www.pollux.fun/profile/me")
            include dash/profile/profile
          #guildsets.switchPanel.hidden
            include dash/guilds2
          #mdl.switchPanel.hidden
            include dash/profile/medals2
          #bgs.switchPanel.hidden
            include dash/profile/backs2 
          #stk.switchPanel.hidden
            include dash/profile/stickers 

      
  //.columns.fullheight.is-gapless 
    
      
        br
        #overviewSettings.tabcontainer.hidden.fullheight(style="margin-top:-55px;overflow:hidden")
        #profileSettings.tabcontainer.hidden.is-hidden-mobile
        #soon.tabcontainer.hidden.is-hidden-mobile
            include soon

