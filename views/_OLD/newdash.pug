    function opensidebar(){
        $('.sidepanel-bg').fadeIn()
        $('.sidepanel').css({
          "transform": "translateX(0)"
        });
    }

        function closeSide(){
          
          $('.sidepanel-bg').fadeOut()
          $('.sidepanel').css({
            "transform": "translateX(-130%)"
          });

        }
        
        $(document).ready(function () {
              console.log(location.hash)
              $('#hideUnowned').click(function(){
                $('.s_see').css({display:"none"})
              })
              $('#showUnowned').click(function(){
                $('.s_see').css({display:"inline-block"})
              })

              switch (location.hash) {

                case "#/overview":
                case "#/general":
                case "#/profile":
                  $("#a1").click()
                  break;
                case "#/medals":
                  $("#a2").click()
                  break;
                case "#/backgrounds":
                  $("#a3").click()
                  break;
                case "#/persotex":
                  $("#a4").click()
                  break;
                case "#/stickers":
                  $("#a5").click()
                  break;
                case "#/servers":
                  $("#a6").click()
                  break;
                case "#/inventory":
                  $("#a7").click()
                  break;
                default:
                  $("#a1").click()
                  break;
              }
            })
            
